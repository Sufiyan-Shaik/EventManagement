@model EventManagement.Models.Event

@{
    ViewData["Title"] = "Delete Event";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <h2>Delete Event</h2>
            <hr />

            <div class="alert alert-danger">
                Are you sure you want to delete this event? This cannot be undone.
            </div>

            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">@Model.Title</h5>
                    <p class="card-text"><strong>Description:</strong> @Model.Description</p>
                    <p class="card-text"><strong>Date:</strong> @Model.Date.ToString("MMM dd, yyyy")</p>
                    <p class="card-text"><strong>Time:</strong> @DateTime.Today.Add(Model.Time).ToString("hh:mm tt")</p>
                    <p class="card-text"><strong>Location:</strong> @Model.Location</p>
                </div>
            </div>

            <div class="d-flex gap-2 mt-4">
                <form asp-action="Delete" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="Id" />
                    <button type="submit" class="btn btn-danger">Yes, Delete</button>
                </form>
                <a asp-action="Index" class="btn btn-secondary">Cancel</a>
            </div>
        </div>
    </div>
</div>

